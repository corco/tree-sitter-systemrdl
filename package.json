{
  "name": "tree-sitter-systemrdl",
  "version": "0.8.0",
  "description": "SystemRDL grammar for tree-sitter",
  "repository": "https://github.com/SystemRDL/tree-sitter-systemrdl",
  "license": "MIT",
  "main": "bindings/node",
  "types": "bindings/node",
  "scripts": {
    "preinstall": "tree-sitter generate",
    "generate": "tree-sitter generate",
    "install": "node-gyp-build",
    "lint": "eslint grammar.js",
    "prestart": "tree-sitter build --wasm",
    "start": "tree-sitter playground",
    "test": "tree-sitter test && node --test bindings/node/*_test.js"
  },
  "author": "Aliaksei Chapyzhenka",
  "bugs": {
    "url": "https://github.com/SystemRDL/tree-sitter-systemrdl/issues"
  },
  "homepage": "https://github.com/SystemRDL/tree-sitter-systemrdl#readme",
  "files": [
    "grammar.js",
    "tree-sitter.json",
    "binding.gyp",
    "prebuilds/**",
    "bindings/node/*",
    "bindings/rust/*",
    "src/**",
    "*.wasm"
  ],
  "keywords": [
    "incremental",
    "parsing",
    "tree-sitter",
    "systemrdl"
  ],
  "dependencies": {
    "node-addon-api": "^8.5.0",
    "node-gyp-build": "^4.8.4"
  },
  "devDependencies": {
    "eslint": "^9.17.0",
    "eslint-config-treesitter": "^1.0.2",
    "prebuildify": "^6.0.1",
    "tree-sitter-cli": "^0.25.10"
  },
  "peerDependencies": {
    "tree-sitter": "^0.25.0"
  },
  "peerDependenciesMeta": {
    "tree-sitter": {
      "optional": true
    }
  },
  "eslintConfig": {
    "extends": "eslint-config-treesitter"
  }
}
